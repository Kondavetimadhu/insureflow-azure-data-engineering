{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-insureflow-dev"
		},
		"ls_adls_insureflow_servicePrincipalCredential": {
			"type": "secureString",
			"metadata": "Secure string for 'servicePrincipalCredential' of 'ls_adls_insureflow'"
		},
		"ls_databricks_insureflow_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_databricks_insureflow'"
		},
		"ls_adls_insureflow_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsinsureflowdev.dfs.core.windows.net/"
		},
		"ls_adls_insureflow_properties_typeProperties_tenant": {
			"type": "string",
			"defaultValue": "4fd172ec-9884-42f7-9132-b8583a21e9eb"
		},
		"ls_adls_insureflow_properties_typeProperties_servicePrincipalId": {
			"type": "string",
			"defaultValue": "cd011591-436f-40ad-918b-813b6c31c780"
		},
		"ls_databricks_insureflow_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0307-181423-fuerrdku"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-insureflow-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_insureflow_servicePrincipalCredential": {
						"value": "[parameters('ls_adls_insureflow_servicePrincipalCredential')]"
					},
					"ls_databricks_insureflow_accessToken": {
						"value": "[parameters('ls_databricks_insureflow_accessToken')]"
					},
					"ls_adls_insureflow_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_insureflow_properties_typeProperties_url')]"
					},
					"ls_adls_insureflow_properties_typeProperties_tenant": {
						"value": "[parameters('ls_adls_insureflow_properties_typeProperties_tenant')]"
					},
					"ls_adls_insureflow_properties_typeProperties_servicePrincipalId": {
						"value": "[parameters('ls_adls_insureflow_properties_typeProperties_servicePrincipalId')]"
					},
					"ls_databricks_insureflow_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_databricks_insureflow_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}